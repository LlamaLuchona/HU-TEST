@{
    ViewData["Title"] = "Sesión expirada";
    Layout = "_Layout";
}

<style>
    body { margin:0; }
    .exp-page { min-height:100vh; display:flex; flex-direction:column; background:#EFEFEF; }
    .exp-card-wrapper { flex:1; display:flex; align-items:center; justify-content:center; padding:2rem 1rem; }
    .exp-card { width:420px; background:white; box-shadow:0 4px 24px rgba(0,0,0,.12); }
    .exp-header { background:var(--ceplan-rojo); height:44px; display:flex; align-items:center;
        justify-content:space-between; padding:0 1rem; }
    .exp-body { padding:2.5rem; text-align:center; }
    .exp-alert { background:#E8EFF8; border:1px solid #C0D4EF; border-radius:6px;
        padding:.8rem 1rem; font-size:.82rem; color:var(--ceplan-azul); margin-top:1rem; }
</style>

<div class="exp-page">
    <div class="topbar">
        <span class="brand">CEPLAN✓</span>
        <button class="help-btn">?</button>
    </div>
    <div class="exp-card-wrapper">
        <div class="exp-card">
            <div class="exp-header">
                <span style="color:white;font-weight:700">CEPLAN✓</span>
                <span class="bi bi-question-circle" style="color:white"></span>
            </div>
            <div class="exp-body">
                <i class="bi bi-clock-history" style="font-size:2.5rem;color:#888;"></i>
                <h5 class="mt-3 fw-bold">Sesión expirada</h5>
                <p style="font-size:.85rem;color:#555;">
                    Su sesión ha expirado por inactividad. Por favor, inicie sesión nuevamente.
                </p>
                <div class="exp-alert">
                    <i class="bi bi-info-circle me-1"></i>
                    Su sesión fue cerrada automáticamente por no haber sido activo durante los últimos 20 minutos.
                </div>
                <a asp-action="Login" asp-controller="Account"
                   class="btn mt-3 w-100"
                   style="background:var(--ceplan-azul);color:white;font-weight:600;font-size:.88rem;">
                    Iniciar sesión nuevamente
                </a>
            </div>
        </div>
    </div>
</div>
