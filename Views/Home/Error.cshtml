@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<style>
    body { margin: 0; }
    .error-page { min-height: 100vh; display: flex; flex-direction: column; background: #EFEFEF; }
    .error-wrapper { flex: 1; display: flex; align-items: center; justify-content: center; }
    .error-card { width: 420px; background: white; box-shadow: 0 4px 24px rgba(0,0,0,.12); text-align: center; }
    .error-header { background: var(--ceplan-rojo); height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 1rem; }
    .error-body { padding: 2.5rem; }
</style>

<div class="error-page">
    <div class="topbar">
        <span class="brand">CEPLAN✓</span>
        <button class="help-btn">?</button>
    </div>
    <div class="error-wrapper">
        <div class="error-card">
            <div class="error-header">
                <span style="color:white;font-weight:700">CEPLAN✓</span>
                <span class="bi bi-question-circle" style="color:white"></span>
            </div>
            <div class="error-body">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:2.5rem;color:#FFC107;"></i>
                <h5 class="mt-3 fw-bold">Ha ocurrido un error</h5>
                <p style="font-size:.85rem;color:#555;">
                    Se produjo un error inesperado. Por favor, intente nuevamente o contacte al área de soporte.
                </p>
                <a asp-action="Login" asp-controller="Account"
                   class="btn mt-2 w-100"
                   style="background:var(--ceplan-azul);color:white;font-weight:600;font-size:.88rem;">
                    <i class="bi bi-arrow-left me-1"></i> Volver al inicio
                </a>
            </div>
        </div>
    </div>
</div>
